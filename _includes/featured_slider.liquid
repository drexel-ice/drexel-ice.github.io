{% if site.data.featured_slides and site.data.featured_slides.size > 0 %}
  <div class="featured-slider">
    <swiper-container
      class="featured-swiper"
      slides-per-view="1"
      space-between="0"
      loop="true"
      pagination="true"
      pagination-clickable="true"
      navigation="true"
      autoplay-delay="6000"
      autoplay-disable-on-interaction="false"
      speed="600"
    >
      {% for slide in site.data.featured_slides %}
        <swiper-slide>
          <a
            class="featured-slide-link"
            href="{% if slide.link contains '://' %}{{ slide.link }}{% else %}{{ slide.link | relative_url }}{% endif %}"
            {% if slide.link contains '://' %}
              target="_blank" rel="noopener noreferrer"
            {% endif %}
          >
            <div class="featured-slide-media">
              {% capture slide_sizes %}(min-width: {{ site.max_width }}) {{ site.max_width }}, 95vw{% endcapture %}
              {% if forloop.first %}
                {%
                  include figure.liquid
                  path=slide.image
                  class="featured-slide-img"
                  loading="eager"
                  alt=slide.title
                  sizes=slide_sizes
                %}
              {% else %}
                {%
                  include figure.liquid
                  path=slide.image
                  class="featured-slide-img"
                  loading="lazy"
                  alt=slide.title
                  sizes=slide_sizes
                %}
              {% endif %}
            </div>
            <div class="featured-slide-caption">
              <h2 class="featured-slide-title">{{ slide.title }}</h2>
              {% if slide.caption %}
                <p class="featured-slide-text">{{ slide.caption }}</p>
              {% endif %}
            </div>
          </a>
        </swiper-slide>
      {% endfor %}
    </swiper-container>
  </div>

  <script>
    (function () {
      var slider = document.querySelector('.featured-swiper');
      if (!slider) return;

      var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) {
        slider.removeAttribute('autoplay-delay');
      }
    })();
  </script>
{% endif %}
