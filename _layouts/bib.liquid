---
---
{% assign author_list = '' %}
{% if entry.author_array %}
  {% assign authors_total = entry.author_array | size %}
  {% for author in entry.author_array %}
    {% capture name %}{{ author.first }} {{ author.last }}{% endcapture %}
    {% assign separator = '' %}
    {% if forloop.first == false %}
      {% if forloop.last %}
        {% if authors_total > 2 %}
          {% assign separator = ', and ' %}
        {% else %}
          {% assign separator = ' and ' %}
        {% endif %}
      {% else %}
        {% assign separator = ', ' %}
      {% endif %}
    {% endif %}
    {% assign author_list = author_list | append: separator | append: name %}
  {% endfor %}
{% endif %}

{% assign proceedings = 'inproceedings,incollection' | split: ',' %}
{% assign thesis = 'thesis,mastersthesis,phdthesis' | split: ',' %}
{% if entry.type == 'article' %}
  {% capture entrytype %}<em>{{ entry.journal }}</em>{% endcapture %}
{% elsif proceedings contains entry.type %}
  {% capture entrytype %}<em>In {{ entry.booktitle }}</em>{% endcapture %}
{% elsif thesis contains entry.type %}
  {% capture entrytype %}<em>{{ entry.school }}</em>{% endcapture %}
{% else %}
  {% capture entrytype %}{% endcapture %}
{% endif %}
{% if entry.location %}
  {% capture entrytype %}{{ entrytype }}{{ ", " }}{{ entry.location }}{% endcapture %}
{% endif %}
{% if entry.additional_info %}
  {% capture entrytype %}{{ entrytype }}{{ entry.additional_info | markdownify | remove: '<p>' | remove: '</p>' }}{% endcapture %}
{% endif %}
{% capture hook_exists %}{% file_exists _includes/hook/bib.liquid %}{% endcapture %}
{% if hook_exists == 'true' %}
  {% include hook/bib.liquid %}
{% endif %}

{% assign entrytype_text = entrytype | strip_html | strip %}
{% assign entrymonth = '' %}
{% if entry.month %}
  {% capture entrymonth %}{{ entry.month | capitalize }}{% endcapture %}
{% endif %}
{% assign entryyear = '' %}
{% if entry.year %}
  {% capture entryyear %}{{ entry.year }}{% endcapture %}
{% endif %}

{% assign detail_segments = '' %}
{% if entrytype_text != '' %}
  {% assign detail_segments = entrytype %}
{% endif %}

{% capture date_segment %}
  {% if entrymonth != '' %}{{ entrymonth }}{% if entryyear != '' %} {% endif %}{% endif %}{{ entryyear }}
{% endcapture %}
{% assign date_segment = date_segment | strip %}
{% if date_segment != '' %}
  {% if detail_segments != '' %}
    {% assign detail_segments = detail_segments | append: ', ' %}
  {% endif %}
  {% assign detail_segments = detail_segments | append: date_segment %}
{% endif %}

{% if entry.pages %}
  {% if detail_segments != '' %}
    {% assign detail_segments = detail_segments | append: ', ' %}
  {% endif %}
  {% assign detail_segments = detail_segments | append: 'pp. ' | append: entry.pages %}
{% endif %}

{% if entry.note %}
  {% if detail_segments != '' %}
    {% assign detail_segments = detail_segments | append: ', ' %}
  {% endif %}
  {% assign detail_segments = detail_segments | append: entry.note %}
{% endif %}

{% assign detail_segments = detail_segments | strip %}

{% capture html_link %}
  {% if entry.html %}
    {% if entry.html contains '://' %}
      {{ entry.html }}
    {% else %}
      {{ entry.html | prepend: '/assets/html/' | relative_url }}
    {% endif %}
  {% endif %}
{% endcapture %}
{% assign html_link = html_link | strip %}

{% capture pdf_link %}
  {% if entry.pdf %}
    {% if entry.pdf contains '://' %}
      {{ entry.pdf }}
    {% else %}
      {{ entry.pdf | prepend: '/assets/pdf/' | relative_url }}
    {% endif %}
  {% endif %}
{% endcapture %}
{% assign pdf_link = pdf_link | strip %}

{% assign title_link = entry.url %}
{% if title_link == blank and html_link != '' %}
  {% assign title_link = html_link %}
{% endif %}
{% if title_link == blank and entry.doi %}
  {% assign title_link = 'https://doi.org/' | append: entry.doi %}
{% endif %}
{% if title_link == blank and pdf_link != '' %}
  {% assign title_link = pdf_link %}
{% endif %}

<div class="row pub-entry" data-pub-year="{{ entry.year }}" data-ice-type="{{ entry.ice_type | default: 'conference_papers' }}">
  <div id="{{ entry.key }}" class="col-12">
    <p class="publication-text">
      {% if author_list != '' %}
        {{ author_list }}.
      {% endif %}
      &ldquo;{% if title_link != blank %}<a href="{{ title_link }}" target="_blank" rel="noopener">{{ entry.title }}</a>{% else %}{{ entry.title }}{% endif %}&rdquo;{% if detail_segments != '' %}, {{ detail_segments }}{% endif %}.
    </p>
  </div>
</div>
